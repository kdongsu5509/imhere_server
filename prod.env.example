# Runtime contract for the private config repo's prod.env.
# This file is documentation-only. The real prod.env lives in ImHereOfRati/config
# and is pulled by .github/workflows/cd.yml -> sync-config job.
#
# Injection flow:
# 1. sync-config clones the private config repo and copies prod.env.
# 2. deploy-app sources prod.env on the GitHub runner to render nginx/alloy templates.
# 3. deploy-app copies prod.env to EC2 and appends RABBITMQ_HOST from CloudFormation output.
# 4. docker compose --profile prod loads this file via env_file for dsko, nginx, alloy.
# 5. deploy-app deletes the copied prod.env from EC2 after compose up.
#
# Important:
# - RABBITMQ_HOST is intentionally NOT stored here. CD appends it from CloudFormation.
# - Grafana Cloud credentials are read only by Alloy, not by the Spring Boot app.

# Which service reads this:
# - dsko: Spring Boot app container
# - nginx: nginx.conf.template renderer on the GitHub runner, then nginx container runtime
# - alloy: alloy-config.alloy.template renderer on the GitHub runner, then alloy container runtime

# -------------------------------------------------------------------
# Spring Boot profile and shared HTTP/security settings
# Used by: dsko
# When: loaded by docker compose on EC2 before the app starts
# -------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
SECURITY_WHITELIST=/api/auth/login,/api/auth/registration,/api/auth/refresh,/swagger-ui/**,/docs/**,/admin/ott/request,/admin/ott/verify,/css/**,/js/**,/images/**,/webjars/**,/favicon.ico
CORS_ALLOWED_ORIGINS=https://ratiko.co.kr
JWT_SECRET=replace-with-real-jwt-secret
LOG_FILE=logs/imhere.log

# -------------------------------------------------------------------
# DB settings
# Used by: dsko -> application.yaml datasource
# When: loaded by docker compose on EC2 before the app starts
# -------------------------------------------------------------------
DB_HOST=replace-with-db-host
DB_PORT=3306
DB_NAME=replace-with-db-name
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_POOL_SIZE=10

# -------------------------------------------------------------------
# RabbitMQ settings
# Used by: dsko -> application.yaml rabbitmq
# When: loaded by docker compose on EC2 before the app starts
# Note: RABBITMQ_HOST is appended by CD from CloudFormation output and does not belong here.
# -------------------------------------------------------------------
RABBITMQ_PORT=5672
RABBITMQ_USER=replace-with-rabbitmq-user
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
RABBITMQ_VHOST=/main
RABBITMQ_CONCURRENCY=3
RABBITMQ_MAX_CONCURRENCY=10

# -------------------------------------------------------------------
# Nginx and management path settings
# Used by:
# - dsko -> application.yaml management.endpoints.web.base-path
# - nginx -> nginx.conf.template renderer during deploy-app
# - alloy -> alloy-config.alloy.template renderer during deploy-app
# When:
# - sourced on the GitHub runner during deploy-app template rendering
# - then loaded again on EC2 by docker compose for nginx/alloy containers
# -------------------------------------------------------------------
SERVER_NAME=ratiko.co.kr
CERT_DOMAIN=ratiko.co.kr
NGINX_ALLOWED_ORIGIN=https://ratiko.co.kr
MGMT_BASE_PATH=/replace-with-random-management-path

# -------------------------------------------------------------------
# Firebase admin key path
# Used by: dsko -> application.yaml firebase.path
# When: loaded by docker compose on EC2 before the app starts
# Note: the actual JSON key file is copied separately to secrets/imhereFirebaseKey.json.
# -------------------------------------------------------------------
FIREBASE_PATH=/app/secrets/imhereFirebaseKey.json

# -------------------------------------------------------------------
# Admin / SMS / Discord integrations
# Used by: dsko
# When: loaded by docker compose on EC2 before the app starts
# -------------------------------------------------------------------
ADMIN_ID=replace-with-admin-id
ADMIN_ALLOWED_IPS=127.0.0.1
SOLAPI_SENDER=01012341234
SOLAPI_API_KEY=replace-with-solapi-key
SOLAPI_API_SECRET=replace-with-solapi-secret
DISCORD_WEBHOOK_ERROR_SERVER=https://discord.com/api/webhooks/server
DISCORD_WEBHOOK_ERROR_CLIENT=https://discord.com/api/webhooks/client
DISCORD_WEBHOOK_OTT=https://discord.com/api/webhooks/ott

# -------------------------------------------------------------------
# Grafana Cloud credentials
# Used by: alloy only -> alloy-config.alloy
# When:
# - sourced on the GitHub runner during deploy-app template rendering
# - loaded again on EC2 by docker compose for the alloy container
# Spring Boot does not read these values directly.
# -------------------------------------------------------------------
GRAFANA_CLOUD_LOKI_ENDPOINT=https://logs-prod-xxx.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=replace-with-loki-user
GRAFANA_CLOUD_LOKI_API_KEY=replace-with-loki-api-key
GRAFANA_CLOUD_PROM_ENDPOINT=https://prometheus-prod-xxx.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=replace-with-prom-user
GRAFANA_CLOUD_PROM_API_KEY=replace-with-prom-api-key
GRAFANA_CLOUD_TEMPO_ENDPOINT=tempo-prod-xxx.grafana.net:443
GRAFANA_CLOUD_TEMPO_USER=replace-with-tempo-user
GRAFANA_CLOUD_TEMPO_API_KEY=replace-with-tempo-api-key
